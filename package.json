{
  "name": "vscode-markdown-tm-grammar",
  "private": true,
  "description": "Grammar used by VS Code's build-in Markdown support",
  "version": "1.0.0",
  "scripts": {
    "build": "node build.ts",
    "test": "node ./test/runTest.ts"
  },
  "engines": {
    "vscode": "^1.55.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mjbvz/vscode-markdown-tm-grammar.git"
  },
  "keywords": [],
  "author": "Microsoft",
  "publisher": "Microsoft",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mjbvz/vscode-markdown-tm-grammar/issues"
  },
  "contributes": {
    "grammars": [
      {
        "language": "markdown",
        "scopeName": "text.html.markdown",
        "path": "./syntaxes/markdown.tmLanguage"
      }
    ]
  },
  "homepage": "https://github.com/mjbvz/vscode-markdown-tm-grammar#readme",
  "devDependencies": {
    "@types/js-yaml": "^3.12.7",
    "@types/node": "^20.0.0",
    "@types/plist": "^3.0.5",
    "js-yaml": "^4.1.1",
    "mocha": "^11.7.5",
    "plist": "^3.1.0",
    "vscode-test": "^1.6.1"
  }
}